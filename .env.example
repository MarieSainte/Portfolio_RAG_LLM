# Copier ce fichier en .env (à la racine) et renseigner les clés

# --- Mistral AI (obligatoire) ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-medium-latest

# --- RAG : découpage des documents (test de chunk sizes, optionnel) ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Journal des interactions (optionnel) ---
# Laisser vide = endpoint /admin/interactions désactivé (404).
# Définir un jeton = active la consultation via l'en-tête X-Admin-Token.
ADMIN_TOKEN=

# --- LangSmith (observabilité / tracing, optionnel) ---
# Créer une clé sur https://smith.langchain.com
# Endpoint UE (données hébergées en Europe) : https://eu.api.smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=portfolio-chatbot

# --- Grafana (prod uniquement : login admin, accès via tunnel SSH) ---
# En local, Grafana est en accès anonyme (voir docker-compose.yml).
# En prod, définir un mot de passe fort (secret GitHub GRAFANA_ADMIN_PASSWORD).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_prod
