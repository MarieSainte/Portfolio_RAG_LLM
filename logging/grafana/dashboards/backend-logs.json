{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "title": "Backend — Logs",
  "uid": "backend-logs",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "level",
        "label": "Niveau",
        "type": "custom",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "query": "INFO,WARNING,ERROR,DEBUG",
        "options": [
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "WARNING", "value": "WARNING", "selected": false },
          { "text": "ERROR", "value": "ERROR", "selected": false },
          { "text": "DEBUG", "value": "DEBUG", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "logs",
      "title": "Logs backend",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"backend\", level=~\"$level\"} | json | line_format \"[{{.level}}] {{.logger}} - {{.message}}\"",
          "queryType": "range"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Débit de logs par niveau (logs/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({job=\"backend\"} [1m]))",
          "queryType": "range",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latence réponse IA (ms)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.5, {job=\"backend\"} | json | latency_ms != \"\" | unwrap latency_ms [$__interval])",
          "queryType": "range",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {job=\"backend\"} | json | latency_ms != \"\" | unwrap latency_ms [$__interval])",
          "queryType": "range",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Latence médiane (dernière heure)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.5, {job=\"backend\"} | json | latency_ms != \"\" | unwrap latency_ms [1h])",
          "queryType": "instant",
          "legendFormat": "p50"
        }
      ]
    }
  ]
}
