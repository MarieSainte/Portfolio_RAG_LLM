# Copier ce fichier en .env et renseigner les clés (exécution locale hors Docker)

# --- Mistral AI (obligatoire) ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-medium-latest

# --- ChromaDB (hors Docker : localhost + port publié 8001) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- LangSmith (observabilité / tracing, optionnel) ---
# Créer une clé sur https://smith.langchain.com
# Endpoint UE (données hébergées en Europe) : https://eu.api.smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=portfolio-chatbot

# --- Évaluation Ragas ---
RAGAS_JUDGE_MODEL=mistral-large-latest
